{
  "name": "@vpro3611/req-shield",
  "version": "1.0.0",
  "description": "A flexible, distributed rate-limiting library with built-in support for Express, NestJS, and Next.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "default": "./dist/middleware/express.js"
    },
    "./nestjs": {
      "types": "./dist/middleware/nestjs.d.ts",
      "default": "./dist/middleware/nestjs.js"
    },
    "./next": {
      "types": "./dist/middleware/next.d.ts",
      "default": "./dist/middleware/next.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "express": "^4.0.0 || ^5.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "next": "^15.1.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  }
}
